<?xml version="1.0" encoding="UTF-8"?>
<!--
  cpsm.wxs - WiX 3.x MSI source for CPSM
  Installs to %LOCALAPPDATA%\Programs\cpsm (per-user, no elevation).
  Code-signing is applied in CI via the release workflow (placeholder path below).

  Build:
    candle.exe -nologo cpsm.wxs -out cpsm.wixobj
    light.exe  -nologo cpsm.wixobj -ext WixUIExtension -out CPSM-0.1.0-x64.msi

  Variables passed on the candle command-line:
    -dVersion=0.1.0
    -dSourceDir=..\..\dist\cpsm
-->
<?define ProductName    = "CPSM" ?>
<?define Manufacturer   = "ITwerx" ?>
<?define UpgradeCode    = "{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}" ?>
<?define InstallSubDir  = "Programs\cpsm" ?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
    Id="*"
    Name="$(var.ProductName)"
    Language="1033"
    Version="$(var.Version)"
    Manufacturer="$(var.Manufacturer)"
    UpgradeCode="$(var.UpgradeCode)">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perUser"
      Platform="x64"
      Description="$(var.ProductName) - Cross-Platform Session Manager"
      Comments="Manages tmux/SSH sessions and Claude Code projects." />

    <!-- Allow upgrades; remove older versions automatically -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of $(var.ProductName) is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- == Directory layout == -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="PROGRAMSFOLDER" Name="Programs">
          <Directory Id="INSTALLFOLDER" Name="cpsm" />
        </Directory>
      </Directory>

      <!-- Start Menu -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="$(var.ProductName)" />
      </Directory>
    </Directory>

    <!-- == Features == -->
    <Feature Id="ProductFeature" Title="$(var.ProductName)" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <!-- == Components: application files ==
         In CI, use heat.exe to enumerate dist\cpsm\ into a fragment file. -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <!-- Primary executable -->
      <Component Id="MainExecutable" Guid="*">
        <File
          Id="CpsmExe"
          Source="$(var.SourceDir)\cpsm.exe"
          KeyPath="yes" />
        <!-- Add to PATH for the current user -->
        <Environment
          Id="PATH"
          Name="PATH"
          Value="[INSTALLFOLDER]"
          Permanent="no"
          Part="last"
          Action="set"
          System="no" />
      </Component>
    </ComponentGroup>

    <!-- == Start Menu shortcut == -->
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="*">
        <Shortcut
          Id="StartMenuShortcut"
          Name="$(var.ProductName)"
          Description="Cross-Platform Session Manager"
          Target="[INSTALLFOLDER]cpsm.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder
          Id="CleanUpShortCut"
          Directory="ApplicationProgramsFolder"
          On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\$(var.Manufacturer)\$(var.ProductName)"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- == UI == -->
    <UIRef Id="WixUI_ProgressOnly" />

    <!-- == Code-signing placeholder ==
         In CI, signtool.exe is invoked after light.exe; see release.yml.
         SIGN_CERT_PATH and SIGN_CERT_PASSWORD must be set as encrypted repo secrets. -->

  </Product>
</Wix>
